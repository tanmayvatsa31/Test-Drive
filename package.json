{
  "name": "acko-design-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "VITE_APP_TARGET=customer vite --config vite.app.config.ts",
    "dev:customer": "VITE_APP_TARGET=customer vite --config vite.app.config.ts",
    "dev:driver": "VITE_APP_TARGET=driver vite --config vite.app.config.ts",
    "dev:admin": "VITE_APP_TARGET=admin vite --config vite.app.config.ts",
    "dev:viewer": "VITE_APP_TARGET=viewer vite --config vite.app.config.ts",
    "dev:all": "node scripts/free-dev-ports.mjs && concurrently --restart-tries 999 --restart-after-delay 2000 -n customer,driver,admin -c blue,green,yellow \"npm:dev:customer\" \"npm:dev:driver\" \"npm:dev:admin\"",
    "dev:demo": "node scripts/free-dev-ports.mjs && concurrently --restart-tries 999 --restart-after-delay 2000 -n customer,driver,admin,viewer -c blue,green,yellow,magenta \"npm:dev:customer\" \"npm:dev:driver\" \"npm:dev:admin\" \"npm:dev:viewer\"",
    "preview:customer": "VITE_APP_TARGET=customer vite preview --config vite.app.config.ts",
    "preview:driver": "VITE_APP_TARGET=driver vite preview --config vite.app.config.ts",
    "preview:admin": "VITE_APP_TARGET=admin vite preview --config vite.app.config.ts",
    "preview:viewer": "VITE_APP_TARGET=viewer vite preview --config vite.app.config.ts",
    "preview:all": "concurrently -n customer,driver,admin -c blue,green,yellow \"npm:preview:customer\" \"npm:preview:driver\" \"npm:preview:admin\"",
    "build": "tsc -b && vite build --config vite.app.config.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@tailwindcss/vite": "^4.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "tailwindcss": "^4.0.0",
    "concurrently": "^9.1.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5"
  }
}
